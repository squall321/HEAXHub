# ─── 기본 ─────────────────────────────────────────────────
# Ports match the Apptainer runtime profile (deploy/apptainer/start.sh).
# Host-mode dev with deploy/dev-host/docker-compose.yml uses the same set.
APP_ENV=development
APP_PORT=4040
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:4040
FRONTEND_BASE_URL=http://localhost:4173

# ─── DB / Redis ──────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://heaxhub:heaxhub@localhost:5732/heaxhub
REDIS_URL=redis://localhost:6479/0

# ─── 인증 (1단계: 자체 가입) ────────────────────────────
AUTH_MODE=local
ALLOWED_EMAIL_DOMAINS=company.com,corp.company.com,example.com
# staging/production 부팅 시 이 placeholder 그대로면 RuntimeError. 생성: openssl rand -hex 64
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800
PASSWORD_MIN_LENGTH=10
EMAIL_VERIFY_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_HOURS=2
# comma-separated; must include the public URL the browser uses (Vite :4173 or Caddy :4180)
CORS_ORIGINS=http://localhost:4173,http://localhost:4180

# ─── 메일 발송 ───────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=8125
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=heaxhub-noreply@example.com
MAIL_DRY_RUN=true

# ─── 인증 (2단계: SSO 전환 시) ──────────────────────────
# OIDC_ISSUER=https://sso.company.com
# OIDC_CLIENT_ID=heaxhub
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# ─── 파일 저장 ───────────────────────────────────────────
JOB_STORAGE_ROOT=./job_storage
WORKSPACE_ROOT=./app_workspaces

# ─── Git 정책 ────────────────────────────────────────────
ALLOWED_GIT_HOSTS=github.com,git.company.com

# ─── 빌드 정책 ───────────────────────────────────────────
PYTHON_BUILD_PATH=/usr/bin/python3
APPTAINER_BIN=/usr/local/bin/apptainer
BUILD_TIMEOUT_SECONDS=1800
# SRV-04: apply per-instance cgroup memory/cpu limits (needs working cgroups). 0=off (safe default).
ENFORCE_INSTANCE_LIMITS=0
# SEC-01(1단계): 앱 인스턴스 파일시스템·권한 격리(--no-home --no-privs). 0=off(기본,
# 도는 앱 무영향). 1=on 이면 앱이 호스트 홈/권한에 못 닿음. 네트워크 격리는 별도.
ENFORCE_INSTANCE_ISOLATION=0

# ─── 빌드 시점 사내 미러 (폐쇄망용) ──────────────────────
# 설정 시 SIF 빌드의 모든 %post 블록 첫 줄에 export 로 주입되어, pip/npm/go 의존성을
# 사내 미러에서 받게 합니다. 실측(apptainer 1.3.6): 호스트 일반 환경변수는 build 시
# %post 로 전달되지 않으므로 이렇게 .def 에 직접 주입해야 미러가 적용됩니다.
# 하나도 설정하지 않으면 완전 no-op(원본 .def 그대로 빌드). 인터넷 환경에서는 비워두세요.
# pip 메인/보조 인덱스 + http 사설 미러 TLS 우회용 trusted-host
BUILD_PIP_INDEX_URL=
BUILD_PIP_EXTRA_INDEX_URL=
BUILD_PIP_TRUSTED_HOST=
# Caddy 가 /pkgs/* 로 서빙하는 사내 휠 미러(var/pkg-mirror/pip/)를 pip --find-links 로 우선 탐색.
# 예: http://localhost:4180/pkgs/pip/  (폐쇄망이 아니면 비워두세요)
BUILD_PIP_FIND_LINKS=
# npm/pnpm 레지스트리 (npm_config_registry 로 주입)
BUILD_NPM_REGISTRY=
# go 모듈 프록시 + 체크섬 DB (사설망이면 보통 GOPROXY=<미러>,direct / GOSUMDB=off)
BUILD_GOPROXY=
BUILD_GOSUMDB=

# ─── 초기 운영자 시드 (scripts/create_admin.py 사용) ────
SEED_ADMIN_EMAIL=admin@example.com
# Quote values with spaces — start.sh/install_all `source .env`, and an unquoted space runs the
# rest as a command (e.g. `Admin: command not found`).
SEED_ADMIN_NAME="System Admin"
SEED_ADMIN_ORG="CAE Automation Part"
SEED_ADMIN_PASSWORD=ChangeMe-On-First-Login!

# ─── v2 공통 인프라 (SA1) ────────────────────────────────
# 앱별 리버스 프록시 포트 풀 범위
APP_PORT_RANGE_LOW=9100
APP_PORT_RANGE_HIGH=9999
# Caddy로 외부에 노출되는 호스트명 (URL 생성에 사용)
PUBLIC_HOST=localhost
# Caddy가 외부에 노출하는 HTTP 포트 (root 권한이 없으므로 80 대신 4180 사용)
PUBLIC_PORT=4180
# Caddy Admin API 엔드포인트
CADDY_ADMIN_URL=http://127.0.0.1:2019
# Fernet 대칭키 (base64로 인코딩된 32바이트). 비어 있으면 secret_manager 호출 시 예외.
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 로테이션 절차: docs/SECRET_ROTATION.md 참고 (기존 secret_values 행 있을 때 주의)
SECRET_ENCRYPTION_KEY=
# Python/Node 인터프리터 매핑 파일 경로 (프로젝트 루트 기준)
INTERPRETERS_CONFIG=config/interpreters.yaml

# ─── GitHub 통합 (SA3 change_request 발행) ──────────────
# 운영자 봇 PAT — repo, pull_request 권한 필요. 비어 있으면 Markdown-only 경로만 동작.
GITHUB_BOT_TOKEN=
# 봇 계정 사용자명 (참고용; PR fork owner 표시)
GITHUB_BOT_USERNAME=heaxhub-bot
# empty disables HMAC verify — MUST set in prod
GITHUB_WEBHOOK_SECRET=
# 데모/연동 테스트용 upstream repo URL
INTEGRATION_REPO_URL=https://github.com/squall321/MXCAEGroupAutomationSample
# comma-separated; falls back to INTEGRATION_REPO_URL
INTEGRATION_REPO_URLS=

# ─── LLM (Manifest Inferrer — SA2) ──────────────────────
# Provider 선택. API 키가 비어 있으면 자동으로 stub 모드로 동작합니다.
LLM_PROVIDER=anthropic
# 외부 모델용 API 키 (anthropic | openai). local 모드에서는 비워두세요.
LLM_API_KEY=
# 모델 이름. 사내 LLM이면 사내 게이트웨이가 인식하는 이름을 입력하세요.
LLM_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8000
# provider=local일 때 사용. 사내 LLM 게이트웨이의 /complete 엔드포인트 기준 base URL.
LLM_LOCAL_ENDPOINT=

# ─── Windows Agent / Installer Hosting (SA5) ─────────────
# Installer .exe 저장 루트 (앱별/OS별/버전별로 하위 경로 생성)
INSTALLER_STORAGE_ROOT=./var/installers
# Windows Agent 의 폴링 주기 (초). 클라이언트가 .env 로 가져갈 수 있음.
WINDOWS_AGENT_POLL_INTERVAL=5

# ─── Apptainer / GPU / License (SA4) ─────────────────────
# Comma-separated apptainer --bind targets that get appended to every job.
# Each entry follows the apptainer bind syntax: host_path[:container_path[:opts]]
# Example: /shared/licenses:/etc/lic,/scratch:/scratch
APPTAINER_DEFAULT_BINDS=
# Logical-name -> absolute SIF path registry (YAML). Manifests reference
# entries via launch.image_ref:{type: registry, name: <key>}.
# OFFLINE: every SIF listed in this file must already exist on disk; the
# platform never pulls images from a registry at runtime.
SIF_REGISTRY_PATH=config/sif_registry.yaml

# ─── Slurm Runner ────────────────────────────────────────
# Absolute paths to the Slurm client binaries. Adjust per site (e.g.
# /usr/bin/sbatch on Debian, /usr/local/slurm/bin/* on source installs).
SLURM_SBATCH_BIN=/usr/local/slurm/bin/sbatch
SLURM_SQUEUE_BIN=/usr/local/slurm/bin/squeue
SLURM_SACCT_BIN=/usr/local/slurm/bin/sacct
SLURM_SCANCEL_BIN=/usr/local/slurm/bin/scancel
# Default partition + time limit applied when manifest.resources omits them.
SLURM_DEFAULT_PARTITION=normal
SLURM_DEFAULT_TIME_MINUTES=60

# ── Behind the HWAX portal (sub-path serving) ───────────────────────────────
# Empty = standalone (served at "/"). To run UNDER the HWAX portal — which reverse-proxies
# https://hwax.sec.samsung.net/heax-hub/ → this app and STRIPS the prefix — build the SPA with
# this base so its asset/router/api/ws URLs carry the prefix:
#   HEAX_BASE_PATH=/heax-hub/
# install_all.sh / Makefile pass it as VITE_BASE_PATH to `pnpm build`. Caddy keeps serving at root
# (the portal strips the prefix), so no Caddy change is needed.
HEAX_BASE_PATH=

# ── Built dist via Google Drive (for cae00: no npm / no Docker Hub) ──────────
# 프론트 dist 를 서버에 넣는 방법은 두 가지 — 둘 다 rclone Drive(HEAX_DRIVE_REMOTE) 공유:
#  (A) pre-built dist 배송 (가장 간단, 서버에 node/pnpm 불필요):
#      (online)  HEAX_BASE_PATH=/heax-hub/ pnpm --dir frontend build && ./deploy/apptainer/dist-to-drive.sh
#      (server)  ./deploy/apptainer/dist-from-drive.sh && bash deploy/apptainer/start.sh
#  (B) 오프라인 서버가 "직접" 빌드 (node+pnpm+deps 를 미러로 나름 — 반복 빌드/앱 SIF npm 용):
#      (online)  ./deploy/apptainer/mirror-to-drive.sh      # node+pnpm tarball + pnpm fetch 스토어 업로드
#      (server)  ./deploy/apptainer/mirror-from-drive.sh    # .tools/ 에 node+pnpm 설치 + 스토어 추출
#                HEAX_BASE_PATH=/heax-hub/ ./deploy/apptainer/build-frontend.sh   # 오프라인 빌드
# Set HEAX_NO_BUILD=1 on cae00 so install_all.sh refuses to auto-build (위 A/B 를 명시적으로 쓰게).
HEAX_DRIVE_REMOTE=
HEAX_DRIVE_RETAIN=3
# HEAX_NO_BUILD=1
