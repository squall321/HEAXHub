Bootstrap: docker
From: golang:1.22
Stage: build

%files
    {{UPSTREAM_DIR}} /src

%post
    set -eux
    cd /src
    mkdir -p /app/bin
    # Build whichever entrypoint the repo provides: prefer ./cmd/server,
    # fallback to root main.go (the convention HEAXHub demos follow).
    if [ -d ./cmd/server ]; then
        CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /app/bin/server ./cmd/server
    else
        CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /app/bin/server .
    fi


Bootstrap: docker
From: debian:stable-slim
Stage: final

%files from build
    /app/bin /app/bin

%post
    set -eux
    apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/app/bin:/usr/local/bin:$PATH

%runscript
    cd /app
    exec {{ENTRYPOINT}} "$@"

%help
    HEAXHub-managed Go service SIF (multi-stage; binary copied from build stage).
    slug: {{SLUG}}
    upstream commit: {{COMMIT}}
    subpath: {{SUBPATH}}
