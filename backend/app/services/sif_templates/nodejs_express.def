Bootstrap: docker
From: node:20-slim

%files
    {{UPSTREAM_DIR}} /app

%post
    set -eux
    apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
    corepack enable
    # ── lockfile-tolerant pnpm install (STK-05) ──────────────────────────────
    # Honour package.json `packageManager` if present; else pin pnpm@9.15.0
    # (corepack default pulls pnpm@latest which needs Node 22+). Try frozen for
    # reproducibility, fall back to --no-frozen-lockfile once on failure.
    cd /app
    if grep -q '"packageManager"' package.json 2>/dev/null; then
        corepack prepare --activate || corepack prepare pnpm@9.15.0 --activate
    else
        corepack prepare pnpm@9.15.0 --activate
    fi
    if [ -f pnpm-lock.yaml ]; then
        pnpm install --frozen-lockfile || {
            echo "WARN[STK-05]: frozen install failed; retrying --no-frozen-lockfile" >&2
            pnpm install --no-frozen-lockfile
        }
    else
        echo "WARN[STK-05]: no pnpm-lock.yaml; installing --no-frozen-lockfile" >&2
        pnpm install --no-frozen-lockfile
    fi
    pnpm build --if-present

%environment
    export NODE_ENV=production
    export PATH=/usr/local/bin:$PATH

%runscript
    cd /app
    exec {{ENTRYPOINT}} "$@"

%help
    HEAXHub-managed Node.js Express / Fastify SIF.
    slug: {{SLUG}}
    upstream commit: {{COMMIT}}
    subpath: {{SUBPATH}}
